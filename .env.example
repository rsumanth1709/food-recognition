# ============================================================
# Food Recognition & Calorie Tracker – Environment Variables
# Copy this file to .env and fill in real values before running
# ============================================================

# ----------------------------------------------------------
# Flask API
# ----------------------------------------------------------
FLASK_SECRET_KEY=change-me-to-a-random-secret-string
FLASK_DEBUG=false
API_HOST=0.0.0.0
API_PORT=5000

# ----------------------------------------------------------
# Streamlit
# ----------------------------------------------------------
# (port is set via CLI flag --server.port, not here)

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
# Absolute or relative path to the SQLite file
DATABASE_PATH=data/foodtracker.db

# ----------------------------------------------------------
# Model / Inference
# ----------------------------------------------------------
MODEL_PATH=models/food_recognition_final.h5
CONFIDENCE_THRESHOLD=0.3
TOP_K_PREDICTIONS=5

# ----------------------------------------------------------
# Upload / Temp files
# ----------------------------------------------------------
# Directory for API file uploads (created automatically)
UPLOAD_FOLDER=uploads

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
LOG_LEVEL=INFO
